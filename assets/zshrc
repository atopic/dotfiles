alias ma="mosh $REMOTE_ARM"
alias mat="mosh $REMOTE_ARM -- tmux new -As 0"
alias sa="ssh $REMOTE_ARM"
alias sat="ssh $REMOTE_ARM -t tmux new -As 0"
alias rssh="remote ssh"
# }

# Lazy-load nvm
export NVM_DIR="$HOME/.nvm"
nvm() {
    unset -f nvm node npm npx
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    nvm "$@"
}
node() { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; node "$@"; }
npm() { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; npm "$@"; }
npx() { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; npx "$@"; }

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000                # commands loaded into memory (for search/autosuggestions)
SAVEHIST=100000                # commands saved to file
setopt SHARE_HISTORY           # sync history across all open shells in real time
setopt HIST_IGNORE_ALL_DUPS    # remove older duplicate when new one is added
setopt HIST_REDUCE_BLANKS      # trim extra whitespace before saving
setopt HIST_IGNORE_SPACE    # prefix with space to exclude from history


