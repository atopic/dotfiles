# Prompt {
setopt PROMPT_SUBST
precmd() {
    # Read branch from .git/HEAD directly — avoids forking git
    local head gitdir d dirty
    _git_prompt=""
    d=$PWD
    while [[ $d != / ]]; do
        if [[ -r $d/.git/HEAD ]]; then
            gitdir=$d/.git
            break
        fi
        d=${d:h}
    done
    if [[ -n $gitdir ]]; then
        read -r head < "$gitdir/HEAD"
        if [[ $head == ref:\ refs/heads/* ]]; then
            head=${head#ref: refs/heads/}
        else
            head=${head:0:8}
        fi
        # Check for any changes (staged, unstaged, or untracked)
        dirty=""
        [[ -n $(git -C "${gitdir:h}" status --porcelain 2>/dev/null) ]] && dirty="%F{red}*"
        _git_prompt="(%F{green}${head}${dirty}%f)"
    fi
}
PROMPT='%F{magenta}%m:%F{cyan}%3~%f${_git_prompt} %# '
